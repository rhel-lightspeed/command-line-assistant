# Use CentOS Stream 10 as the base image
FROM quay.io/fedora/fedora:45@sha256:cf75ca062db05d48a613c74f66f69e2a094c713f84da3ec02035f4de8344d69f

# Install Python, pip, and development tools
RUN dnf install -y \
    python3-pip \
    'pkgconfig(cairo)' \
    'pkgconfig(cairo-gobject)' \
    'pkgconfig(gobject-introspection-1.0)' \
    'pkgconfig(mariadb)' \
    /usr/bin/pg_config && \
    dnf clean all

# Upgrade pip
RUN python -m pip install --upgrade pip

# Set up a working directory
WORKDIR /workspace
