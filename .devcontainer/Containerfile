# Use CentOS Stream 10 as the base image
FROM quay.io/fedora/fedora:42@sha256:90fa1c898df395095eb72ddb74d7c64ce33d6f0f19131b65a456b53edf9e1ca4

# Install Python, pip, and development tools
RUN dnf install -y \
    python3-pip \
    'pkgconfig(cairo)' \
    'pkgconfig(cairo-gobject)' \
    'pkgconfig(gobject-introspection-1.0)' \
    'pkgconfig(mariadb)' \
    /usr/bin/pg_config && \
    dnf clean all

# Upgrade pip
RUN python -m pip install --upgrade pip

# Set up a working directory
WORKDIR /workspace
